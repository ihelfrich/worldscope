{
  "name": "worldscope-site",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build pipeline for the WORLDSCOPE daily-briefing site (GitHub Pages).",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/src/tailwind.input.css -o ./dist/assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/src/tailwind.input.css -o ./dist/assets/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "daisyui": "^4.12.10",
    "tailwindcss": "^3.4.10"
  }
}
